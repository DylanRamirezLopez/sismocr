# SismosCR Backend — copy to .env and fill in your values
APP_NAME=SismosCR
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL (defaults to SQLite if unset)
DATABASE_URL=postgresql+asyncpg://sismocr:CHANGE_ME@localhost:5432/sismocr

# Redis (defaults to in-memory cache if unset)
REDIS_URL=redis://localhost:6379/0

# WebSocket
WS_MAX_CONNECTIONS=1000
WS_HEARTBEAT_INTERVAL=30

# Ingestion
USGS_POLL_INTERVAL=60
SCRAPE_INTERVAL=120

# CR Bounding Box
CR_BBOX_LAT_MIN=8.0
CR_BBOX_LAT_MAX=11.5
CR_BBOX_LON_MIN=-86.0
CR_BBOX_LON_MAX=-82.0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# API v2 feature flag
ENABLE_API_V2=true
